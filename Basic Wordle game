#Wordle game


import random

#Get a random word from the file
file = open("random-words.txt", "r")
words = file.read().splitlines()
target = random.choice(words).lower()
file.close()

print("Welcome You have 5 chances to gues the word")


for i in range(1, 6):
    guess = input("Enter guess " + str(i) + ": ").lower()
    result = ""
    
    #Check letters
    for x in range(5):
        if guess[x] == target[x]:
            result += "📗" # Correct spot
        elif guess[x] in target:
            result += "🟨" # Wrong spot but letter exzist in original word
        else:
            result += "⬛" # Not in word
            
    print(result)
    
    if guess == target:
        print("YOU WON!")
        break
else:
    # This runs if the loop finishes without a break statement
    print("Lost! The word was: " , target)
